# =============================================================================
# Environment variables for kaggle-COMPETITION_NAME
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is gitignored.
# =============================================================================

# --- Anthropic API -----------------------------------------------------------
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Cost guard --------------------------------------------------------------
# The agent will stop and raise an error if total API spend exceeds this value.
# Set to a low value during development (e.g. 0.50) to avoid surprises.
MAX_COST_USD=1.00

# --- Logging -----------------------------------------------------------------
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Log file path (leave empty to log to stdout only)
LOG_FILE=
